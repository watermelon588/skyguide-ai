# SkyGuide AI — FastAPI Astro Engine environment
# Copy to `.env` and fill in real values. Never commit `.env`.

APP_NAME=SkyGuide Astro Engine
APP_ENV=development
APP_PORT=8000

# --- Database (MongoDB Atlas via Motor) ---
MONGO_URI=your-mongodb-atlas-uri
DATABASE_NAME=your-database-name

# --- Internal service auth ---
# Shared secret; MUST match the gateway's INTERNAL_API_KEY. When set, every
# /api/v1 request requires it in the `X-Internal-Key` header. Leave empty in
# development to disable enforcement; with APP_ENV=production the engine
# REFUSES TO START without it.
INTERNAL_API_KEY=

# --- CORS ---
# Comma-separated browser origins allowed to call the engine directly.
# In production this must be the real frontend origin(s) only — never a wildcard.
CORS_ORIGINS=http://localhost:5173

# --- Weather (OpenWeather) ---
# Get a free key at https://home.openweathermap.org/api_keys
# Optional: the service boots without it and fails cleanly (503) on weather calls.
OPENWEATHER_API_KEY=
