# SkyGuide AI — Express Gateway environment
# Copy to `.env` and fill in real secrets + your LAN IP / tunnel URLs.

PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=your-mongodb-atlas-uri

# Auth
JWT_SECRET=your-jwt-secret

# FastAPI Astro Engine (server-to-server)
FASTAPI_URL=http://localhost:8000

# Email (Nodemailer)
EMAIL_USER=your-email
EMAIL_PASS=your-app-password

# AI (Groq)
GROQ_API_KEY=your-groq-key

# ─────────────────────────────────────────────────────────────
# Network mode: local | lan | tunnel   (production reserved)
# CORS allows every URL below regardless of mode (never a wildcard).
# ─────────────────────────────────────────────────────────────
NETWORK_MODE=local
LOCAL_CLIENT_URL=http://localhost:5173
LAN_CLIENT_URL=http://192.168.1.15:5173
TUNNEL_CLIENT_URL=https://your-subdomain.trycloudflare.com

# Legacy / extra allowed origins (comma-separated). Merged into CORS allow-list.
CLIENT_URL=http://localhost:5173
